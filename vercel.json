{
  "rewrites": [
    { "source": "/ccp", "destination": "/index.html" },
    { "source": "/ccp/", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/admin/", "destination": "/index.html" },
    { "source": "/configurator", "destination": "/index.html" },
    { "source": "/configurator/", "destination": "/index.html" },
    { "source": "/impressum", "destination": "/index.html" },
    { "source": "/impressum/", "destination": "/index.html" },
    { "source": "/datenschutz", "destination": "/index.html" },
    { "source": "/datenschutz/", "destination": "/index.html" },
    { "source": "/agb", "destination": "/index.html" },
    { "source": "/agb/", "destination": "/index.html" },
    { "source": "/widerruf", "destination": "/index.html" },
    { "source": "/widerruf/", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: blob: https:; media-src 'self' blob:; font-src 'self' data: https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://accounts.google.com https://apis.google.com; connect-src 'self' https: wss:; frame-src https://accounts.google.com; worker-src 'self' blob:;"
        }
      ]
    }
  ]
}
