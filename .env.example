# ============================================================
# Umgebungsvariablen – Kopie nach .env.local (lokal) oder in
# Vercel/Netlify → Settings → Environment Variables (Deploy).
# ============================================================

# ---- Pflicht für Konfigurator, Microsite, CCP, Admin ----
# Supabase: Project Settings → API → Project URL und anon (public) key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---- Admin-Panel ----
# Login über Supabase Auth (E-Mail/Passwort).
# User in Authentication anlegen + E-Mail in Tabelle admin_users eintragen.
# Siehe SUPABASE_SETUP.md – kein VITE_ADMIN_PASSWORD mehr.

# ---- Optional: Google-Login im Konfigurator ----
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
VITE_GOOGLE_CLIENT_ID=

# ---- Optional: Microsite-Assistent (KI) ----
# Kein VITE_-Key! OPENAI_API_KEY nur als Supabase Edge Function Secret
# für supabase/functions/microsite-chat – siehe AI_MICROSITE_CHAT.md

# ---- Optional: Observability (Sentry) ----
# Browser-DSN aus Sentry-Projekt; ohne DSN kein Tracking.
# Wird erst nach Cookie-Einwilligung („Alle akzeptieren“) geladen.
VITE_SENTRY_DSN=

# ---- Recht: Shopify-Policy-Links (empfohlen) ----
# Einfach die URLs aus Shopify Admin → Einstellungen → Rechtliches hier eintragen.
# Footer und /impressum etc. öffnen dann direkt deinen Shop-Text.
# VITE_LEGAL_IMPRESSUM_URL=https://nudaim3d.de/policies/legal-notice
# VITE_LEGAL_DATENSCHUTZ_URL=https://nudaim3d.de/policies/privacy-policy
# VITE_LEGAL_AGB_URL=https://nudaim3d.de/policies/terms-of-service
# VITE_LEGAL_WIDERRUF_URL=https://nudaim3d.de/policies/refund-policy
# Optional Anzeige:
# VITE_LEGAL_COMPANY_NAME=
# VITE_LEGAL_EMAIL=
# VITE_LEGAL_SHOP_URL=https://nudaim3d.de

# ---- Go-Live (Standard) ----
# Unfertige Features aus = Kunden bestellen über Shopify-Warenkorb.
# Später alles wieder an: VITE_FEATURES_FULL=1
# VITE_FEATURES_FULL=0

# ---- Shopify Variant-IDs (echte IDs aus Shopify Admin) ----
# VITE_SHOPIFY_VARIANT_KEYCHAIN=56564338262361
# VITE_SHOPIFY_VARIANT_BADGE=
# Optional: Staffel-Varianten nur noch manuell im Shop – Konfigurator nutzt sie
# bewusst NICHT mehr für /cart/add (Preis-Gaming). Mengenpreis nur via Draft Order.
# VITE_SHOPIFY_VARIANT_KEYCHAIN_Q10=
# VITE_SHOPIFY_VARIANT_KEYCHAIN_Q25=

# ---- Preise im Konfigurator ----
# WICHTIG: /cart/add rechnet IMMER den Shopify-Katalogpreis der Variante ab.
# VITE_PRICE_* steuert Anzeige + Draft-Order-Staffel – muss zum Shop-Preis passen.
# Beträge als Euro (24.90 / 1.50) oder Cent (2490 / 150):
# VITE_PRICE_KEYCHAIN_CENTS=1.50
# VITE_PRICE_KEYCHAIN_Q10_CENTS=1.20
# VITE_PRICE_KEYCHAIN_Q25_CENTS=1.00
# VITE_PRICE_BADGE_CENTS=39.90
# VITE_PRICE_BADGE_Q10_CENTS=34.90
# VITE_PRICE_BADGE_Q25_CENTS=29.90
# Optional explizit Katalogpreis (Anzeige/Doku); sonst = VITE_PRICE_* Einzelpreis:
# VITE_SHOPIFY_CATALOG_PRICE_KEYCHAIN_CENTS=1.50

# ---- Shopify Draft Orders (berechneter Preis → Kasse) ----
# Edge Secrets (nicht VITE_): siehe SHOPIFY_DRAFT_ORDER.md
# Ohne Secrets: Fallback auf Cart (Katalogpreis). Mit Secrets: echter Staffelpreis.
# SHOPIFY_SHOP_DOMAIN=dein-shop.myshopify.com
# SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_…
# PRICE_KEYCHAIN_CENTS=1.50
# PRICE_KEYCHAIN_Q10_CENTS=1.20
# PRICE_KEYCHAIN_Q25_CENTS=1.00

# ---- Shopify Order-Webhook (nur Supabase Edge Secrets, nicht VITE_) ----
# SHOPIFY_WEBHOOK_SECRET=…  → siehe SHOPIFY_WEBHOOK.md
